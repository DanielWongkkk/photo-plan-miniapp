/**
 * 拍照策划小程序 - 全局样式
 */

/* ==================== CSS Variables ==================== */
page {
  /* Brand Colors */
  --brand-primary: #FF6B35;
  --brand-primary-light: #FF8F5A;
  --brand-primary-dark: #E55A28;
  --brand-gradient: linear-gradient(135deg, #FF6B35 0%, #FF8F5A 100%);
  
  /* Accent Colors */
  --accent-gold: #FFB347;
  --accent-teal: #2EC4B6;
  --accent-coral: #FF6B6B;
  --accent-blue: #4A90D9;
  
  /* Neutral Colors */
  --gray-900: #1A1A2E;
  --gray-700: #4A4A68;
  --gray-500: #7A7A8C;
  --gray-300: #B0B0C0;
  --gray-200: #D8D8E0;
  --gray-100: #F0F0F5;
  --gray-50: #F8F8FA;
  --white: #FFFFFF;
  
  /* Shadows */
  --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4px 12px rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 8px 24px rgba(0, 0, 0, 0.12);
  --shadow-brand: 0 8px 24px rgba(255, 107, 53, 0.3);
  
  /* Spacing */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 32rpx;
  --spacing-lg: 48rpx;
  --spacing-xl: 64rpx;
  
  /* Border Radius */
  --radius-sm: 16rpx;
  --radius-md: 24rpx;
  --radius-lg: 32rpx;
  --radius-xl: 48rpx;
  --radius-full: 9999rpx;
  
  /* Font */
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Noto Sans SC', sans-serif;
  font-size: 28rpx;
  color: var(--gray-900);
  background-color: var(--gray-50);
  line-height: 1.5;
}

/* ==================== Common Components ==================== */

/* Primary Button */
.btn-primary {
  width: 100%;
  height: 104rpx;
  background: var(--brand-gradient);
  border-radius: var(--radius-xl);
  border: none;
  color: var(--white);
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-brand);
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-primary[disabled] {
  background: var(--gray-300);
  box-shadow: none;
}

/* Secondary Button */
.btn-secondary {
  width: 100%;
  height: 88rpx;
  background: var(--white);
  border-radius: var(--radius-md);
  border: 2rpx solid var(--gray-200);
  color: var(--gray-700);
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-secondary:active {
  background: var(--gray-50);
}

/* Card */
.card {
  background: var(--white);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  box-shadow: var(--shadow-sm);
}

/* Input Field */
.input-field {
  width: 100%;
  height: 104rpx;
  background: var(--white);
  border: 2rpx solid var(--gray-200);
  border-radius: var(--radius-md);
  padding: 0 var(--spacing-md);
  font-size: 30rpx;
  color: var(--gray-900);
}

.input-field:focus {
  border-color: var(--brand-primary);
}

/* Section Label */
.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--gray-700);
  margin-bottom: var(--spacing-sm);
  display: flex;
  align-items: center;
}

.section-label .required {
  color: var(--accent-coral);
  margin-left: 4rpx;
}

/* ==================== Utilities ==================== */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.text-center {
  text-align: center;
}

.text-primary {
  color: var(--brand-primary);
}

.text-gray {
  color: var(--gray-500);
}

.mt-sm { margin-top: var(--spacing-sm); }
.mt-md { margin-top: var(--spacing-md); }
.mt-lg { margin-top: var(--spacing-lg); }
.mb-sm { margin-bottom: var(--spacing-sm); }
.mb-md { margin-bottom: var(--spacing-md); }
.mb-lg { margin-bottom: var(--spacing-lg); }

/* Safe Area */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}