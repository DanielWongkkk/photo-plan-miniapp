/* 拍照策划小程序 - 首页样式 */

.page-container {
  min-height: 100vh;
  background: var(--gray-50);
  padding: 32rpx;
  padding-bottom: 200rpx;
}

/* 表单区块 */
.form-section {
  margin-bottom: 48rpx;
}

.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--gray-700);
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.section-label .required {
  color: var(--accent-coral);
  margin-left: 4rpx;
}

/* 输入框 */
.input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.input-field {
  flex: 1;
  height: 104rpx;
  background: var(--white);
  border: 2rpx solid var(--gray-200);
  border-radius: 24rpx;
  padding: 0 80rpx 0 72rpx;
  font-size: 30rpx;
  color: var(--gray-900);
}

.input-icon {
  position: absolute;
  left: 24rpx;
  font-size: 36rpx;
}

.input-clear {
  position: absolute;
  right: 24rpx;
  width: 40rpx;
  height: 40rpx;
  background: var(--gray-200);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--gray-600);
}

/* 最近地点 */
.recent-tags {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  margin-top: 16rpx;
  gap: 12rpx;
}

.recent-label {
  font-size: 24rpx;
  color: var(--gray-500);
}

.recent-tag {
  font-size: 24rpx;
  color: var(--gray-500);
  background: var(--gray-100);
  padding: 8rpx 20rpx;
  border-radius: 32rpx;
}

/* 日期时间行 */
.datetime-row {
  display: flex;
  gap: 16rpx;
}

.datetime-item {
  flex: 1;
  height: 104rpx;
  background: var(--white);
  border: 2rpx solid var(--gray-200);
  border-radius: 24rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.datetime-icon {
  font-size: 32rpx;
}

.datetime-value {
  flex: 1;
  font-size: 28rpx;
  color: var(--gray-300);
}

.datetime-value.has-value {
  color: var(--gray-900);
}

.datetime-arrow {
  font-size: 20rpx;
  color: var(--gray-400);
}

/* 风格选择 */
.style-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.style-chip {
  width: calc(25% - 12rpx);
  height: 80rpx;
  background: var(--white);
  border: 2rpx solid var(--gray-200);
  border-radius: 40rpx;
  font-size: 26rpx;
  color: var(--gray-700);
  display: flex;
  align-items: center;
  justify-content: center;
}

.style-chip.selected {
  background: var(--brand-gradient);
  border-color: transparent;
  color: var(--white);
  font-weight: 600;
}

/* 文本域 */
.textarea-field {
  width: 100%;
  min-height: 160rpx;
  background: var(--white);
  border: 2rpx solid var(--gray-200);
  border-radius: 24rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: var(--gray-900);
}

/* 底部按钮 */
.bottom-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, transparent 0%, var(--gray-50) 30%);
}

.btn-generate {
  width: 100%;
  height: 104rpx;
  background: var(--brand-gradient);
  border: none;
  border-radius: 48rpx;
  color: var(--white);
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: var(--shadow-brand);
}

.btn-generate:active {
  transform: scale(0.98);
}

.generate-icon {
  font-size: 36rpx;
}

.hidden-picker {
  display: none;
}