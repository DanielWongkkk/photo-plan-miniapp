/* 拍照策划小程序 - 首页样式 */

.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F0 0%, #FFFFFF 50%);
  padding-bottom: 160rpx;
}

/* 顶部用户信息 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 32rpx 24rpx;
}

.header-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.greeting {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.subtitle {
  font-size: 28rpx;
  color: #7A7A8C;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

/* AI 推荐区域 */
.recommend-section {
  margin: 0 32rpx 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.title-icon {
  font-size: 28rpx;
}

.view-more {
  font-size: 26rpx;
  color: #FF6B35;
}

/* 轮播卡片 */
.recommend-swiper {
  height: 320rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.recommend-card {
  display: flex;
  height: 100%;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.08);
}

.rec-cover {
  width: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.rec-emoji {
  font-size: 64rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.2));
}

.rec-hot {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: rgba(255,255,255,0.95);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #FF6B35;
  font-weight: 500;
}

.rec-content {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.rec-week {
  font-size: 22rpx;
  color: #7A7A8C;
  background: #F5F5F7;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  align-self: flex-start;
}

.rec-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.rec-subtitle {
  font-size: 26rpx;
  color: #4A4A68;
}

.rec-tags {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
}

.rec-tag {
  font-size: 22rpx;
  color: #FF6B35;
  background: #FFF5F0;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.rec-location {
  font-size: 24rpx;
  color: #7A7A8C;
  margin-top: auto;
}

/* 轮播指示器 */
.swiper-indicator {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-top: 20rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #E0E0E0;
  transition: all 0.3s;
}

.dot.active {
  width: 32rpx;
  border-radius: 6rpx;
  background: #FF6B35;
}

/* 表单区域 */
.form-section {
  margin: 0 32rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.form-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 24rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0F0F5;
}

.form-item:last-child {
  border-bottom: none;
}

.item-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: #4A4A68;
  margin-bottom: 16rpx;
}

.label-icon {
  font-size: 28rpx;
}

.required {
  color: #FF6B35;
}

.item-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.value {
  font-size: 30rpx;
  color: #1A1A2E;
  font-weight: 500;
}

.placeholder {
  font-size: 30rpx;
  color: #B0B0C0;
}

.arrow {
  color: #B0B0C0;
  font-size: 28rpx;
}

.location-input {
  flex: 1;
  font-size: 30rpx;
  color: #1A1A2E;
}

.date-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}

/* 多行输入 */
.textarea-item {
  align-items: flex-start;
}

.notes-input {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  color: #1A1A2E;
  background: #F8F8FA;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-top: 8rpx;
}

/* 提交按钮 */
.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, transparent 0%, #FFFFFF 40%);
}

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8F5A 100%);
  border-radius: 48rpx;
  border: none;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 53, 0.3);
}

.btn-icon {
  font-size: 32rpx;
}

/* 选择器内容 */
.picker-content {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  max-height: 60vh;
  overflow-y: auto;
}

/* 主题网格 */
.theme-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.theme-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 16rpx;
  background: #F8F8FA;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.theme-item.selected {
  background: #FFF5F0;
  border-color: #FF6B35;
}

.theme-icon {
  font-size: 48rpx;
}

.theme-name {
  font-size: 26rpx;
  color: #4A4A68;
}

.theme-item.selected .theme-name {
  color: #FF6B35;
  font-weight: 500;
}

/* 时间列表 */
.time-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.time-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #F8F8FA;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.time-item.selected {
  background: #FFF5F0;
  border-color: #FF6B35;
}

.time-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.time-icon {
  font-size: 40rpx;
}

.time-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.time-name {
  font-size: 30rpx;
  color: #1A1A2E;
  font-weight: 500;
}

.time-desc {
  font-size: 24rpx;
  color: #7A7A8C;
}

.check-icon {
  font-size: 32rpx;
  color: #FF6B35;
  font-weight: 600;
}

/* 风格列表 */
.style-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.style-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: #F8F8FA;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.style-item.selected {
  background: #FFF5F0;
  border-color: #FF6B35;
}

.style-color {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
}

.style-name {
  flex: 1;
  font-size: 30rpx;
  color: #1A1A2E;
}

/* 设备列表 */
.equipment-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.equipment-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #F8F8FA;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.equipment-item.selected {
  background: #FFF5F0;
  border-color: #FF6B35;
}

.equipment-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.equipment-name {
  font-size: 30rpx;
  color: #1A1A2E;
  font-weight: 500;
}

.equipment-lens {
  font-size: 26rpx;
  color: #7A7A8C;
}

/* 空状态 */
.empty-equipment {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  padding: 48rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #7A7A8C;
}

.add-equipment-btn {
  padding: 16rpx 48rpx;
  background: #FF6B35;
  color: #fff;
  font-size: 28rpx;
  border-radius: 24rpx;
  border: none;
}