/* 拍照策划小程序 - 登录页样式 */

.page-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #FFF9F5 0%, #FFFFFF 100%);
  position: relative;
  overflow: hidden;
}

/* 装饰背景 */
.bg-decoration {
  position: absolute;
  pointer-events: none;
}

.bg-circle-1 {
  width: 600rpx;
  height: 600rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 107, 53, 0.08) 0%, transparent 70%);
  top: -200rpx;
  right: -160rpx;
}

.bg-circle-2 {
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 179, 71, 0.1) 0%, transparent 70%);
  bottom: 20%;
  left: -120rpx;
}

/* 主内容 */
.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 64rpx 48rpx;
  position: relative;
  z-index: 1;
}

/* 品牌区域 */
.brand-section {
  text-align: center;
  margin-bottom: 96rpx;
}

.brand-logo {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 32rpx;
  background: var(--brand-gradient);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-brand);
}

.logo-img {
  width: 80rpx;
  height: 80rpx;
}

.brand-name {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: var(--gray-900);
  letter-spacing: -1rpx;
  margin-bottom: 16rpx;
}

.brand-tagline {
  display: block;
  font-size: 30rpx;
  color: var(--gray-500);
}

/* 登录卡片 */
.login-card {
  width: 100%;
  max-width: 680rpx;
}

/* 微信登录按钮 */
.btn-wechat {
  width: 100%;
  height: 104rpx;
  background: #07C160;
  color: white;
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(7, 193, 96, 0.3);
}

.btn-wechat:active {
  background: #06AD56;
  transform: scale(0.98);
}

.wechat-icon {
  font-size: 40rpx;
}

/* 分割线 */
.divider {
  display: flex;
  align-items: center;
  margin: 48rpx 0;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: var(--gray-100);
}

.divider-text {
  padding: 0 32rpx;
  font-size: 26rpx;
  color: var(--gray-300);
}

/* 头像上传 */
.avatar-section {
  text-align: center;
  margin-bottom: 32rpx;
}

.avatar-upload {
  width: 144rpx;
  height: 144rpx;
  margin: 0 auto 16rpx;
  border-radius: 50%;
  background: var(--gray-100);
  border: 4rpx dashed var(--gray-300);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: 1;
}

.avatar-upload.has-image {
  border-style: solid;
  border-color: var(--brand-primary);
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-placeholder {
  font-size: 56rpx;
}

.avatar-hint {
  font-size: 26rpx;
  color: var(--gray-500);
}

/* 输入框 */
.input-group {
  margin-bottom: 32rpx;
}

.input-field {
  width: 100%;
  height: 104rpx;
  background: var(--gray-50);
  border: 3rpx solid transparent;
  border-radius: 32rpx;
  padding: 0 32rpx;
  font-size: 32rpx;
  color: var(--gray-900);
}

.input-field:focus {
  background: var(--white);
  border-color: var(--brand-primary);
}

/* 提交按钮 */
.btn-submit {
  width: 100%;
  height: 104rpx;
  background: var(--brand-gradient);
  color: white;
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: var(--shadow-brand);
  margin-top: 32rpx;
}

.btn-submit:active {
  transform: scale(0.98);
}

.btn-submit[disabled] {
  background: var(--gray-300);
  box-shadow: none;
}

/* 底部 */
.footer {
  text-align: center;
  padding: 32rpx;
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
}

.footer-text {
  font-size: 24rpx;
  color: var(--gray-500);
}

.footer-link {
  font-size: 24rpx;
  color: var(--brand-primary);
  font-weight: 500;
}