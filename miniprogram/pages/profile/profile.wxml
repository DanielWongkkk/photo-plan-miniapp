<!-- 拍照策划小程序 - 个人中心 -->
<view class="page-container">
  <!-- 用户卡片 -->
  <view class="user-card">
    <image class="user-avatar" src="{{userInfo.avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
    <text class="user-name">{{userInfo.nickname || '未登录'}}</text>
    <view class="user-badge">
      <text class="badge-icon">⭐</text>
      <text class="badge-text">{{userInfo.memberType === 'vip' ? 'VIP会员' : '免费用户'}}</text>
    </view>
    <view class="user-stats">
      <view class="stat-item">
        <text class="stat-value">{{usageCount}}</text>
        <text class="stat-label">今日已用</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{totalPlans}}</text>
        <text class="stat-label">累计策划</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{equipments.length}}</text>
        <text class="stat-label">设备数量</text>
      </view>
    </view>
  </view>
  
  <!-- 我的设备 -->
  <view class="section-card">
    <view class="section-header">
      <view class="section-title">
        <text class="title-icon">📷</text>
        <text>我的设备</text>
      </view>
      <text class="header-action" bindtap="goToEquipmentManage">管理 ></text>
    </view>
    <view class="equipment-list">
      <view 
        class="equipment-item {{item.isDefault ? 'is-default' : ''}}" 
        wx:for="{{equipments}}" 
        wx:key="id"
        bindtap="editEquipment"
        data-id="{{item.id}}"
      >
        <view class="equipment-icon">📷</view>
        <view class="equipment-info">
          <text class="equipment-name">{{item.name}}</text>
          <text class="equipment-detail">{{item.camera.type}} · {{item.lens.focalLength}}mm</text>
        </view>
        <text wx:if="{{item.isDefault}}" class="equipment-badge">默认</text>
        <text class="equipment-arrow">›</text>
      </view>
      <view class="equipment-add" bindtap="addEquipment">
        <text class="add-icon">+</text>
        <text>添加新设备</text>
      </view>
    </view>
  </view>
  
  <!-- 历史策划 -->
  <view class="section-card">
    <view class="section-header">
      <view class="section-title">
        <text class="title-icon">📋</text>
        <text>历史策划</text>
      </view>
      <text class="header-action" bindtap="goToHistory">全部 ></text>
    </view>
    <view class="history-list" wx:if="{{recentPlans.length}}">
      <view 
        class="history-item" 
        wx:for="{{recentPlans}}" 
        wx:key="id"
        bindtap="viewPlan"
        data-id="{{item.id}}"
      >
        <image class="history-thumb" src="{{item.thumbnail || '/images/placeholder.png'}}" mode="aspectFill"></image>
        <view class="history-info">
          <text class="history-title">{{item.location}} · {{item.theme}}</text>
          <text class="history-date">{{item.date}}</text>
        </view>
        <text class="history-arrow">›</text>
      </view>
    </view>
    <view class="empty-state" wx:else>
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无历史策划</text>
    </view>
  </view>
  
  <!-- 设置 -->
  <view class="section-card">
    <view class="section-title">
      <text class="title-icon">⚙️</text>
      <text>设置</text>
    </view>
    <view class="settings-list">
      <view class="setting-item" bindtap="editCity">
        <text class="setting-label">默认城市</text>
        <view class="setting-value">
          <text>{{userInfo.city || '未设置'}}</text>
          <text class="setting-arrow">›</text>
        </view>
      </view>
      <view class="setting-item" bindtap="editStyles">
        <text class="setting-label">风格偏好</text>
        <view class="setting-value">
          <text>{{userInfo.stylePreferences ? userInfo.stylePreferences.join('、') : '未设置'}}</text>
          <text class="setting-arrow">›</text>
        </view>
      </view>
      <view class="setting-item" bindtap="showAbout">
        <text class="setting-label">关于我们</text>
        <text class="setting-arrow">›</text>
      </view>
      <view class="setting-item" bindtap="clearCache">
        <text class="setting-label">清除缓存</text>
        <text class="setting-arrow">›</text>
      </view>
    </view>
  </view>
  
  <!-- 退出登录 -->
  <button class="btn-logout" bindtap="logout">退出登录</button>
</view>