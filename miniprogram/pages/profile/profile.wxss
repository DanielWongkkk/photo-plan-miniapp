/* 拍照策划小程序 - 个人中心样式 */

.page-container {
  min-height: 100vh;
  background: var(--gray-50);
  padding: 32rpx;
  padding-bottom: 64rpx;
}

/* 用户卡片 */
.user-card {
  background: var(--brand-gradient);
  border-radius: 32rpx;
  padding: 48rpx 32rpx 32rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.user-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  margin-bottom: 16rpx;
}

.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--white);
  margin-bottom: 12rpx;
}

.user-badge {
  display: inline-flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 32rpx;
  padding: 8rpx 20rpx;
  margin-bottom: 24rpx;
}

.badge-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.badge-text {
  font-size: 24rpx;
  color: var(--white);
}

.user-stats {
  display: flex;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 24rpx;
  padding: 24rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--white);
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

.stat-divider {
  width: 1rpx;
  background: rgba(255, 255, 255, 0.3);
  margin: 0 16rpx;
}

/* 区块卡片 */
.section-card {
  background: var(--white);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--gray-900);
}

.title-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.header-action {
  font-size: 26rpx;
  color: var(--brand-primary);
}

/* 设备列表 */
.equipment-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.equipment-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: var(--gray-50);
  border-radius: 16rpx;
}

.equipment-item.is-default {
  background: linear-gradient(135deg, rgba(255, 107, 53, 0.08) 0%, var(--gray-50) 100%);
}

.equipment-icon {
  width: 64rpx;
  height: 64rpx;
  background: var(--white);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 16rpx;
}

.equipment-info {
  flex: 1;
}

.equipment-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--gray-900);
}

.equipment-detail {
  display: block;
  font-size: 24rpx;
  color: var(--gray-500);
  margin-top: 4rpx;
}

.equipment-badge {
  font-size: 22rpx;
  color: var(--brand-primary);
  background: rgba(255, 107, 53, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  margin-right: 12rpx;
}

.equipment-arrow {
  font-size: 32rpx;
  color: var(--gray-300);
}

.equipment-add {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  color: var(--brand-primary);
  font-size: 28rpx;
}

.add-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

/* 历史列表 */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: var(--gray-50);
  border-radius: 16rpx;
}

.history-thumb {
  width: 96rpx;
  height: 96rpx;
  border-radius: 12rpx;
  background: var(--gray-200);
  margin-right: 16rpx;
}

.history-info {
  flex: 1;
}

.history-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--gray-900);
}

.history-date {
  display: block;
  font-size: 24rpx;
  color: var(--gray-500);
  margin-top: 4rpx;
}

.history-arrow {
  font-size: 32rpx;
  color: var(--gray-300);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 48rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--gray-500);
}

/* 设置列表 */
.settings-list {
  display: flex;
  flex-direction: column;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--gray-100);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 28rpx;
  color: var(--gray-900);
}

.setting-value {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: var(--gray-500);
}

.setting-arrow {
  font-size: 32rpx;
  color: var(--gray-300);
  margin-left: 8rpx;
}

/* 退出登录 */
.btn-logout {
  width: 100%;
  height: 88rpx;
  background: var(--white);
  border: 2rpx solid var(--accent-coral);
  border-radius: 44rpx;
  font-size: 28rpx;
  color: var(--accent-coral);
  margin-top: 24rpx;
}

.btn-logout:active {
  background: rgba(239, 71, 111, 0.05);
}