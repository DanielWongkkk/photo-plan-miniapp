<!-- 拍照策划小程序 - 结果页 -->
<view class="page-container">
  <!-- 顶部摘要 -->
  <view class="header-card">
    <view class="header-title">{{plan.summary}}</view>
    <view class="header-meta">
      <text class="meta-item">📍 {{plan.input.location}}</text>
      <text class="meta-item">📷 {{plan.input.equipmentName}}</text>
    </view>
  </view>

  <!-- 最佳拍摄时间（天气驱动） -->
  <view class="section-card weather-section">
    <view class="section-title">
      <text class="title-icon">🕐</text>
      <text>最佳拍摄时间</text>
    </view>
    
    <!-- 推荐日期选择 -->
    <view class="date-recommend" wx:if="{{plan.recommendedDates && plan.recommendedDates.length}}">
      <scroll-view scroll-x class="date-scroll">
        <view class="date-item {{item.recommended ? 'recommended' : ''}} {{item.selected ? 'selected' : ''}}" 
              wx:for="{{plan.recommendedDates}}" 
              wx:key="date"
              bindtap="selectDate"
              data-index="{{index}}">
          <view class="date-weekday">{{item.weekday}}</view>
          <view class="date-num">{{item.dateNum}}</view>
          <view class="date-weather">{{item.weather}}</view>
          <view class="date-score" wx:if="{{item.score}}">
            <text class="score-star">⭐</text>
            <text>{{item.score}}</text>
          </view>
        </view>
      </scroll-view>
    </view>
    
    <!-- 时间段推荐 -->
    <view class="time-slots" wx:if="{{plan.timeSlots && plan.timeSlots.length}}">
      <view class="time-slot {{item.recommended ? 'recommended' : ''}}" 
            wx:for="{{plan.timeSlots}}" 
            wx:key="period">
        <view class="slot-time">{{item.period}}</view>
        <view class="slot-desc">{{item.description}}</view>
        <view class="slot-light">
          <text class="light-icon">{{item.lightIcon}}</text>
          <text>{{item.lightCondition}}</text>
        </view>
        <view class="slot-tag" wx:if="{{item.recommended}}">推荐</view>
      </view>
    </view>
  </view>

  <!-- 具体取景点（带定位导航） -->
  <view class="section-card">
    <view class="section-title">
      <text class="title-icon">📍</text>
      <text>具体取景点</text>
      <text class="spot-count">共 {{plan.shootingSpots.length}} 处</text>
    </view>
    
    <view class="spot-card" wx:for="{{plan.shootingSpots}}" wx:key="id">
      <view class="spot-header">
        <view class="spot-badge">{{index + 1}}</view>
        <view class="spot-info">
          <text class="spot-name">{{item.name}}</text>
          <text class="spot-address">{{item.address}}</text>
        </view>
        <view class="spot-actions">
          <button class="btn-nav" bindtap="openNavigation" data-spot="{{item}}">
            <text class="nav-icon">🧭</text>
            <text>导航</text>
          </button>
        </view>
      </view>
      
      <!-- 该位置的样片（有真实图片时显示） -->
      <view class="spot-samples" wx:if="{{item.samples && item.samples.length && item.samples[0].imageUrl}}">
        <view class="samples-title">📷 参考样片（点击查看拍摄方法）</view>
        <scroll-view scroll-x class="sample-scroll">
          <view class="sample-item" wx:for="{{item.samples}}" wx:for-item="sample" wx:key="imageUrl" bindtap="toggleSampleAnalysis" data-index="{{index}}" data-sample-index="{{index2}}">
            <image class="sample-img" src="{{sample.imageUrl}}" mode="aspectFill" lazy-load />
            <view class="sample-source">
              <text class="source-icon">{{sample.sourceIcon}}</text>
              <text class="source-name">{{sample.source}}</text>
            </view>
            <view class="sample-likes" wx:if="{{sample.likes}}">❤️ {{sample.likes}}</view>
          </view>
        </scroll-view>
        
        <!-- 样片 AI 分析结果 -->
        <view class="sample-analysis" wx:if="{{item.showSampleAnalysis && item.currentSample}}">
          <view class="analysis-header">
            <text class="analysis-title">💡 如何拍出这张效果</text>
            <text class="analysis-close" bindtap="closeSampleAnalysis" data-index="{{index}}">收起</text>
          </view>
          
          <view class="analysis-content" wx:if="{{item.currentSample.analysis}}">
            <!-- 光线分析 -->
            <view class="analysis-section">
              <text class="section-label">☀️ 光线</text>
              <view class="analysis-tags">
                <text class="tag" wx:if="{{item.currentSample.analysis.lightDirection}}">{{item.currentSample.analysis.lightDirection}}</text>
                <text class="tag" wx:if="{{item.currentSample.analysis.lightQuality}}">{{item.currentSample.analysis.lightQuality}}</text>
                <text class="tag" wx:if="{{item.currentSample.analysis.timeOfDay}}">{{item.currentSample.analysis.timeOfDay}}</text>
              </view>
            </view>
            
            <!-- 机位构图 -->
            <view class="analysis-section">
              <text class="section-label">📐 机位构图</text>
              <view class="analysis-tags">
                <text class="tag" wx:if="{{item.currentSample.analysis.cameraAngle}}">{{item.currentSample.analysis.cameraAngle}}</text>
              </view>
              <text class="analysis-detail" wx:if="{{item.currentSample.analysis.composition}}">{{item.currentSample.analysis.composition}}</text>
            </view>
            
            <!-- 摆姿引导（人像） -->
            <view class="analysis-section" wx:if="{{item.currentSample.analysis.poseGuide}}">
              <text class="section-label">💃 摆姿引导</text>
              <text class="analysis-detail">{{item.currentSample.analysis.poseGuide}}</text>
            </view>
            
            <!-- 拍摄建议 -->
            <view class="analysis-section">
              <text class="section-label">📍 场地建议</text>
              <text class="analysis-detail">{{item.currentSample.analysis.locationTips}}</text>
            </view>
            
            <!-- 参数建议 -->
            <view class="analysis-section" wx:if="{{item.currentSample.analysis.suggestedParams}}">
              <text class="section-label">⚙️ 参数参考</text>
              <text class="analysis-detail param">{{item.currentSample.analysis.suggestedParams}}</text>
            </view>
            
            <!-- 拍摄要点 -->
            <view class="analysis-section" wx:if="{{item.currentSample.analysis.keyPoints && item.currentSample.analysis.keyPoints.length}}">
              <text class="section-label">📝 拍摄要点</text>
              <view class="key-points">
                <view class="point-item" wx:for="{{item.currentSample.analysis.keyPoints}}" wx:for-item="point" wx:key="*this">
                  <text class="point-dot">•</text>
                  <text>{{point}}</text>
                </view>
              </view>
            </view>
            
            <!-- 难度 -->
            <view class="analysis-section" wx:if="{{item.currentSample.analysis.difficulty}}">
              <text class="section-label">📊 难度</text>
              <text class="difficulty-tag {{item.currentSample.analysis.difficulty}}">{{item.currentSample.analysis.difficulty}}</text>
            </view>
          </view>
          
          <!-- AI 未返回分析时的提示 -->
          <view class="analysis-empty" wx:else>
            <text>暂无分析结果</text>
            <text class="view-link" bindtap="openSearchLink" data-url="{{item.currentSample.link}}">在小红书查看详情 ></text>
          </view>
        </view>
      </view>
      
      <!-- 样片搜索链接（无图片时显示） -->
      <view class="search-links-section" wx:if="{{item.samples && item.samples.searchLinks && !item.samples.images.length}}">
        <view class="search-tip">{{item.samples.tip || '点击搜索更多样片参考'}}</view>
        <view class="search-links-grid">
          <button class="search-link-btn xiaohongshu" bindtap="openSearchLink" data-url="{{item.samples.searchLinks.xiaohongshu.url}}">
            📕 小红书
          </button>
          <button class="search-link-btn tuchong" bindtap="openSearchLink" data-url="{{item.samples.searchLinks.tuchong.url}}">
            🖼️ 图虫
          </button>
          <button class="search-link-btn huaban" bindtap="openSearchLink" data-url="{{item.samples.searchLinks.huaban.url}}">
            🌸 花瓣
          </button>
          <button class="search-link-btn baidu" bindtap="openSearchLink" data-url="{{item.samples.searchLinks.baidu.url}}">
            🔍 百度图片
          </button>
        </view>
      </view>
      
      <!-- 拍摄要点 -->
      <view class="spot-tips">
        <view class="tip-item">
          <text class="tip-label">📸 拍摄角度：</text>
          <text>{{item.angle}}</text>
        </view>
        <view class="tip-item">
          <text class="tip-label">🕐 最佳时间：</text>
          <text>{{item.bestTime}}</text>
        </view>
        <view class="tip-item" wx:if="{{item.params}}">
          <text class="tip-label">⚙️ 参数参考：</text>
          <text>{{item.params}}</text>
        </view>
      </view>
      
      <!-- 人像摆姿引导 -->
      <view class="pose-guide" wx:if="{{plan.input.theme === '人像' && item.poseGuide}}">
        <view class="pose-title">💃 摆姿引导</view>
        <view class="pose-content">{{item.poseGuide}}</view>
        <view class="pose-images" wx:if="{{item.poseImages && item.poseImages.length}}">
          <image class="pose-img" wx:for="{{item.poseImages}}" wx:for-item="poseImg" wx:key="url" src="{{poseImg.url}}" mode="aspectFill" bindtap="previewPose" data-url="{{poseImg.url}}" data-images="{{item.poseImages}}" />
        </view>
      </view>
    </view>
  </view>

  <!-- 设备参数配置 -->
  <view class="section-card">
    <view class="section-title">
      <text class="title-icon">⚙️</text>
      <text>参数配置</text>
    </view>
    <view class="params-grid">
      <view class="param-item">
        <text class="param-label">镜头</text>
        <text class="param-value">{{plan.equipmentConfig.lens}}</text>
      </view>
      <view class="param-item">
        <text class="param-label">光圈</text>
        <text class="param-value">{{plan.equipmentConfig.aperture}}</text>
      </view>
      <view class="param-item">
        <text class="param-label">快门</text>
        <text class="param-value">{{plan.equipmentConfig.shutter}}</text>
      </view>
      <view class="param-item">
        <text class="param-label">ISO</text>
        <text class="param-value">{{plan.equipmentConfig.iso}}</text>
      </view>
      <view class="param-item" wx:if="{{plan.equipmentConfig.whiteBalance}}">
        <text class="param-label">白平衡</text>
        <text class="param-value">{{plan.equipmentConfig.whiteBalance}}</text>
      </view>
      <view class="param-item" wx:if="{{plan.equipmentConfig.filters}}">
        <text class="param-label">滤镜</text>
        <text class="param-value">{{plan.equipmentConfig.filters}}</text>
      </view>
    </view>
    <view class="params-tips" wx:if="{{plan.equipmentConfig.tips}}">
      <text class="tips-icon">💡</text>
      <text>{{plan.equipmentConfig.tips}}</text>
    </view>
  </view>

  <!-- 拍摄清单 -->
  <view class="section-card">
    <view class="section-header">
      <view class="section-title">
        <text class="title-icon">📝</text>
        <text>拍摄清单</text>
      </view>
      <view class="shot-progress">
        <text>{{completedShots}}/{{plan.shotList.length}}</text>
      </view>
    </view>
    
    <view class="shot-item" wx:for="{{plan.shotList}}" wx:key="order">
      <view class="shot-header" bindtap="toggleShot" data-index="{{index}}">
        <view class="shot-check" bindtap="toggleShotCheck" data-index="{{index}}">
          <text class="check-icon">{{item.completed ? '✅' : '⬜'}}</text>
        </view>
        <view class="shot-main">
          <view class="shot-title">
            <text class="shot-order">{{item.order}}.</text>
            <text class="shot-name">{{item.name}}</text>
          </view>
          <view class="shot-meta">
            <text class="shot-type">{{item.shotType}}</text>
            <text class="shot-angle">{{item.angle}}</text>
          </view>
        </view>
        <text class="shot-expand">{{item.expanded ? '▼' : '▶'}}</text>
      </view>
      
      <view class="shot-detail" wx:if="{{item.expanded}}">
        <view class="detail-row">
          <text class="detail-label">📐 构图：</text>
          <text>{{item.composition}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">⚙️ 参数：</text>
          <text>{{item.params}}</text>
        </view>
        <view class="detail-row" wx:if="{{item.poseGuide}}">
          <text class="detail-label">💃 摆姿：</text>
          <text>{{item.poseGuide}}</text>
        </view>
        <view class="detail-row" wx:if="{{item.tips}}">
          <text class="detail-label">💡 提示：</text>
          <text>{{item.tips}}</text>
        </view>
        
        <!-- 该拍摄项的样片参考 -->
        <view class="shot-samples" wx:if="{{item.samples && item.samples.length}}">
          <text class="samples-label">📷 样片参考：</text>
          <scroll-view scroll-x class="samples-scroll">
            <view class="sample-thumb" wx:for="{{item.samples}}" wx:for-item="s" wx:key="imageUrl" bindtap="previewSample" data-url="{{s.imageUrl}}" data-samples="{{item.samples}}">
              <image src="{{s.imageUrl}}" mode="aspectFill" lazy-load />
              <text class="sample-source-tag">{{s.source}}</text>
            </view>
          </scroll-view>
        </view>
      </view>
    </view>
  </view>

  <!-- 后期建议 -->
  <view class="section-card" wx:if="{{plan.postProcessing}}">
    <view class="section-title">
      <text class="title-icon">🎨</text>
      <text>后期建议</text>
    </view>
    <view class="post-content">
      <view class="post-style">
        <text class="style-label">风格：</text>
        <text class="style-value">{{plan.postProcessing.style}}</text>
      </view>
      <view class="post-steps" wx:if="{{plan.postProcessing.steps && plan.postProcessing.steps.length}}">
        <text class="steps-title">调色步骤：</text>
        <view class="step-item" wx:for="{{plan.postProcessing.steps}}" wx:key="index">
          <text>{{item}}</text>
        </view>
      </view>
      <view class="post-presets" wx:if="{{plan.postProcessing.lrPresets}}">
        <text class="presets-label">Lightroom 预设参考：</text>
        <text class="presets-value">{{plan.postProcessing.lrPresets}}</text>
      </view>
    </view>
  </view>

  <!-- 注意事项 -->
  <view class="section-card notice-card" wx:if="{{plan.notices && plan.notices.length}}">
    <view class="section-title">
      <text class="title-icon">⚠️</text>
      <text>注意事项</text>
    </view>
    <view class="notice-list">
      <view class="notice-item" wx:for="{{plan.notices}}" wx:key="index">
        <text class="notice-dot">•</text>
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 底部操作 -->
  <view class="bottom-bar">
    <button class="btn-icon-text" bindtap="savePlan">
      <text class="btn-icon">💾</text>
      <text>保存</text>
    </button>
    <button class="btn-icon-text" bindtap="exportPlan">
      <text class="btn-icon">📄</text>
      <text>导出</text>
    </button>
    <button class="btn-primary" bindtap="startShooting">
      <text class="btn-icon">📸</text>
      <text>开始拍摄</text>
    </button>
  </view>
</view>