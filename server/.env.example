# 服务端口
PORT=3000

# 微信小程序
WX_APPID=your_appid
WX_SECRET=your_secret

# JWT 密钥
JWT_SECRET=your_jwt_secret_here

# AI 模型 API Keys（选择配置一个即可）
# 通义千问
QWEN_API_KEY=sk-xxx

# DeepSeek
DEEPSEEK_API_KEY=sk-xxx

# 智谱 GLM
GLM_API_KEY=xxx.xxx

# 默认 AI 提供商：qwen / deepseek / glm
AI_PROVIDER=qwen

# ==================== 样片搜索配置 ====================

# 国际平台（可选，作为备选）
# Unsplash: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key
# Pexels: https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key

# 图虫（可选，需要登录 cookie）
# 登录 tuchong.com 后从浏览器获取
TUCHONG_COOKIE=

# ==================== 小红书配置 ====================
# 获取方式：
# 1. 登录 https://www.xiaohongshu.com
# 2. F12 打开开发者工具
# 3. Application → Cookies → www.xiaohongshu.com
# 4. 复制 web_session 的值
XIAOHONGSHU_WEB_SESSION=