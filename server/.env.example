# 服务端口
PORT=3000

# 微信小程序
WX_APPID=your_appid
WX_SECRET=your_secret

# JWT 密钥
JWT_SECRET=your_jwt_secret_here

# AI 模型 API Keys（选择配置一个即可）
# 通义千问
QWEN_API_KEY=sk-xxx

# DeepSeek
DEEPSEEK_API_KEY=sk-xxx

# 智谱 GLM
GLM_API_KEY=xxx.xxx

# 默认 AI 提供商：qwen / deepseek / glm
AI_PROVIDER=qwen

# 样片搜索 API Keys（国际平台）
# Unsplash: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# Pexels: https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key

# 国内样片搜索
# 图虫 Cookie（登录后从浏览器获取，可选）
# 格式: TUCHONG_COOKIE=sessionid=xxx; user_id=xxx
TUCHONG_COOKIE=